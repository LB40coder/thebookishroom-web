# Database (Vercel Neon integration sets POSTGRES_PRISMA_URL automatically)
# You can also set DATABASE_URL manually — both work.
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Required for admin panel & bot API (generate with: npm run generate-secrets)
ADMIN_PATH=""
ADMIN_API_KEY=""
SESSION_SECRET=""
ADMIN_PASSWORD_HASH=""
