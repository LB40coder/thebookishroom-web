# Database (Vercel Neon integration sets POSTGRES_PRISMA_URL automatically)
# You can also set DATABASE_URL manually — both work.
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Required for admin panel & bot API (generate with: npm run generate-secrets)
ADMIN_PATH=""
ADMIN_API_KEY=""
SESSION_SECRET=""
ADMIN_PASSWORD_HASH=""

# Vercel Blob for Studio image uploads (Storage → Blob → Connect to project)
# Vercel injects these automatically — no manual setup needed after connecting:
# BLOB_STORE_ID, VERCEL_OIDC_TOKEN (on deploy), and optionally BLOB_READ_WRITE_TOKEN
# Local dev: run `vercel link` then `vercel env pull`
