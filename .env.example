# Database (Vercel Postgres or Neon)
DATABASE_URL="postgresql://user:password@host:5432/bookish_room"

# Secret admin URL path (min 12 chars) — e.g. cms-a1b2c3d4e5f6g7h8
# Access admin at: https://yoursite.com/{ADMIN_PATH}/login
ADMIN_PATH=""

# API key for your bot (min 32 chars) — generate with: npm run generate-secrets
ADMIN_API_KEY=""

# Session signing secret (min 32 chars)
SESSION_SECRET=""

# Bcrypt hash of admin password — generate with: npm run generate-secrets
ADMIN_PASSWORD_HASH=""
